---
import "../styles/global.css";
import SEOHead from "../components/layout/SEOHead.astro";
import Footer from "../components/layout/Footer.astro";
import WhatsAppButton from "../components/layout/WhatsAppButton.astro";
import MegaMenuHeader from "../components-react/MegaMenuHeader";
import { switchPath } from "../data/navigation";

export interface Props {
  title: string;
  description: string;
  lang?: "es" | "en";
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hideHeaderSpacer?: boolean;
}

const {
  title,
  description,
  lang = "es",
  canonical,
  ogImage,
  ogType,
  noindex,
  jsonLd,
  hideHeaderSpacer = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://snaconsultoriaacustica.com";
const alternatePath = switchPath(currentPath);
const alternateUrl = `${site}${alternatePath}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet" />
    <SEOHead
      title={title}
      description={description}
      lang={lang}
      canonical={canonical}
      alternateUrl={alternateUrl}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-primary-foreground focus:px-4 focus:py-2">
      Saltar al contenido principal
    </a>

    <MegaMenuHeader lang={lang} currentPath={currentPath} client:load />

    {/* Spacer for fixed header */}
    {!hideHeaderSpacer && <div class="h-16 lg:h-20" aria-hidden="true"></div>}

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer lang={lang} />
    <WhatsAppButton />
  </body>
</html>
