---
import "../styles/global.css";
import SEOHead from "../components/layout/SEOHead.astro";
import Footer from "../components/layout/Footer.astro";
import WhatsAppButton from "../components/layout/WhatsAppButton.astro";
import MegaMenuHeader from "../components-react/MegaMenuHeader";
import { switchPath } from "../data/navigation";
import SpeedInsights from "@vercel/speed-insights/astro";

export interface Props {
  title: string;
  description: string;
  lang?: "es" | "en";
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hideHeaderSpacer?: boolean;
}

const {
  title,
  description,
  lang = "es",
  canonical,
  ogImage,
  ogType,
  noindex,
  jsonLd,
  hideHeaderSpacer = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://snaconsultoriaacustica.com";
const alternatePath = switchPath(currentPath);
const alternateUrl = `${site}${alternatePath}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet" /></noscript>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-W8H4TZXM');</script>
    <!-- End Google Tag Manager -->
    <SEOHead
      title={title}
      description={description}
      lang={lang}
      canonical={canonical}
      alternateUrl={alternateUrl}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <SpeedInsights />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W8H4TZXM" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-primary-foreground focus:px-4 focus:py-2">
      Saltar al contenido principal
    </a>

    <MegaMenuHeader lang={lang} currentPath={currentPath} client:load />

    {/* Spacer for fixed header */}
    {!hideHeaderSpacer && <div class="h-16 lg:h-20" aria-hidden="true"></div>}

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer lang={lang} />
    <WhatsAppButton />
  </body>
</html>
