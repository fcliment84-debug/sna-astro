---
export interface Props {
  title: string;
  background?: "white" | "muted";
  id?: string;
}

const { title, background = "white", id } = Astro.props;
---

<section
  class:list={[
    "py-20 lg:py-28",
    background === "muted" ? "bg-muted" : "bg-background",
  ]}
  id={id}
>
  <div class="max-w-[800px] mx-auto px-6 lg:px-8">
    <h2 class="text-2xl lg:text-[34px] font-semibold mb-8 leading-tight">{title}</h2>
    <div class="space-y-6 text-foreground/80 leading-relaxed">
      <slot />
    </div>
  </div>
</section>
