---
const WHATSAPP_URL = "https://wa.me/34669307211";
---

<a
  href={WHATSAPP_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg transition-all hover:scale-110 hover:shadow-xl hover:bg-sna-accent hover:text-sna-dark"
>
  {/* WhatsApp / MessageCircle icon */}
  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="none">
    <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z" />
  </svg>
</a>
