---
import { Image } from "astro:assets";
import pilaresHeroImg from "../../assets/hero/pilares-hero.webp";
import innovacionImg from "../../assets/metodologia/innovacion-aplicada.webp";
import diagnosticoImg from "../../assets/metodologia/camara-acustica-sna.webp";
import capacidadImg from "../../assets/metodologia/capacidad-tecnica.webp";

export interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;

const texts = {
  es: {
    heading: "Más de 25 años rompiendo los límites de lo convencional.",
    sub: "Tres ejes vertebran nuestra forma de abordar cada proyecto: innovación aplicada, diagnóstico riguroso y capacidad técnica para resolver lo que otros no pueden.",
    innovLabel: "Innovación",
    innovTitle: "Innovación aplicada",
    innovDesc: "Integramos herramientas de diagnóstico avanzado, modelización computacional y soluciones técnicas propias. Basslock®, nuestra última solución patentada, nació de una pregunta que el mercado no respondía.",
    diagLabel: "Diagnóstico",
    diagTitle: "Diagnóstico avanzado",
    diagDesc: "Análisis espectral, caracterización del campo sonoro e identificación de vías de transmisión.",
    capLabel: "Capacidad técnica",
    capTitle: "Capacidad técnica compleja",
    capDesc: "Proyectos multidisciplinares con ingeniería de detalle, supervisión de obra y validación final in situ.",
    cta: "Descubre nuestra metodología",
    imgAltHero: "Detalle de instalación acústica técnica",
    imgAltInnov: "Diseño acústico — simulación y verificación",
    imgAltDiag: "Análisis espectral y diagnóstico acústico",
    imgAltCap: "Entorno industrial con soluciones técnicas complejas",
  },
  en: {
    heading: "Over 25 years pushing the limits of conventional acoustics.",
    sub: "Three pillars shape our approach to every project: applied innovation, rigorous diagnosis and the technical capability to solve what others cannot.",
    innovLabel: "Innovation",
    innovTitle: "Applied innovation",
    innovDesc: "We integrate advanced diagnostic tools, computational modelling and proprietary technical solutions. Basslock®, our latest patented solution, was born from a question the market could not answer.",
    diagLabel: "Diagnosis",
    diagTitle: "Advanced diagnosis",
    diagDesc: "Spectral analysis, sound field characterisation and identification of transmission paths.",
    capLabel: "Technical capability",
    capTitle: "Complex technical capability",
    capDesc: "Multidisciplinary projects with detailed engineering, site supervision and final on-site validation.",
    cta: "Discover our methodology",
    imgAltHero: "Detail of acoustic technical installation",
    imgAltInnov: "Acoustic design — simulation and verification",
    imgAltDiag: "Spectral analysis and acoustic diagnosis",
    imgAltCap: "Industrial environment with complex technical solutions",
  },
};

const t = texts[lang];
const metodoBase = lang === "en" ? "/en/methodology" : "/metodologia";
const disenoHref = `${metodoBase}/${lang === "en" ? "design" : "diseno"}`;
const diagHref = `${metodoBase}/${lang === "en" ? "diagnosis" : "diagnostico"}`;
const ejecHref = `${metodoBase}/${lang === "en" ? "execution" : "ejecucion"}`;

const boltClip = "polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px)";
---

<section id="pilares" class="py-16 lg:py-20" aria-labelledby="pilares-heading">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-3">
      {/* Hero card */}
      <div
        class="lg:col-span-7 lg:row-span-2 overflow-hidden relative min-h-[320px] lg:min-h-0 group"
        style={`clip-path: ${boltClip}`}
      >
        <Image src={pilaresHeroImg} alt={t.imgAltHero} class="w-full h-full object-cover absolute inset-0" width={800} height={533} loading="lazy" />
        <div class="absolute inset-0 bg-black/20"></div>
        <div class="relative z-10 flex flex-col justify-center h-full p-8 lg:p-10">
          <div class="flex flex-col lg:flex-row lg:items-center gap-6">
            <div class="flex-1">
              <h2 id="pilares-heading" class="text-2xl lg:text-3xl font-semibold text-white max-w-lg leading-snug">{t.heading}</h2>
              <p class="text-sm lg:text-base text-white/70 mt-3 max-w-md leading-relaxed">{t.sub}</p>
            </div>
            <svg class="hidden lg:block text-white/60 flex-shrink-0 transition-transform duration-300 group-hover:translate-x-2 group-hover:text-sna-accent" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            <svg class="lg:hidden text-white/60 mx-auto transition-transform duration-300 group-hover:translate-y-2 group-hover:text-sna-accent" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </div>
        </div>
      </div>

      {/* Innovation card */}
      <a
        href={disenoHref}
        class="lg:col-span-5 relative overflow-hidden group cursor-pointer transition-all duration-500 block border-b-2 border-transparent hover:shadow-xl hover:border-sna-accent"
      >
        <div class="absolute inset-0 z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-[hsl(78_83%_60%/0.07)] shadow-[inset_0_0_30px_hsl(78_83%_60%/0.12)]"></div>
        <Image src={innovacionImg} alt={t.imgAltInnov} class="w-full h-36 lg:h-40 object-cover transition-transform duration-300 group-hover:scale-105" width={800} height={160} loading="lazy" />
        <div class="bg-muted p-4">
          <span class="text-xs tracking-widest uppercase font-medium text-primary group-hover:text-sna-accent transition-colors duration-500">{t.innovLabel}</span>
          <h3 class="text-base font-semibold mt-1.5 leading-snug">{t.innovTitle}</h3>
          <p class="text-sm text-foreground/80 mt-1.5 leading-relaxed line-clamp-3">{t.innovDesc}</p>
        </div>
      </a>

      {/* Diagnosis + Capability cards */}
      <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a
          href={diagHref}
          class="relative overflow-hidden group cursor-pointer flex flex-col transition-all duration-500 border-b-2 border-transparent hover:shadow-xl hover:border-sna-accent"
        >
          <div class="absolute inset-0 z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-[hsl(78_83%_60%/0.07)] shadow-[inset_0_0_30px_hsl(78_83%_60%/0.12)]"></div>
          <div class="overflow-hidden h-28 flex-shrink-0">
            <Image src={diagnosticoImg} alt={t.imgAltDiag} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" width={600} height={112} loading="lazy" />
          </div>
          <div class="bg-muted p-4 flex-1">
            <span class="text-xs tracking-widest uppercase font-medium text-primary group-hover:text-sna-accent transition-colors duration-500">{t.diagLabel}</span>
            <h3 class="text-sm font-semibold mt-1.5 leading-snug">{t.diagTitle}</h3>
            <p class="text-xs text-foreground/80 mt-1.5 leading-relaxed line-clamp-3">{t.diagDesc}</p>
          </div>
        </a>

        <a
          href={ejecHref}
          class="relative overflow-hidden group cursor-pointer flex flex-col transition-all duration-500 border-b-2 border-transparent hover:shadow-xl hover:border-sna-accent"
        >
          <div class="absolute inset-0 z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-[hsl(78_83%_60%/0.07)] shadow-[inset_0_0_30px_hsl(78_83%_60%/0.12)]"></div>
          <div class="overflow-hidden h-28 flex-shrink-0">
            <Image src={capacidadImg} alt={t.imgAltCap} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" width={600} height={112} loading="lazy" />
          </div>
          <div class="bg-muted p-4 flex-1">
            <span class="text-xs tracking-widest uppercase font-medium text-primary group-hover:text-sna-accent transition-colors duration-500">{t.capLabel}</span>
            <h3 class="text-sm font-semibold mt-1.5 leading-snug">{t.capTitle}</h3>
            <p class="text-xs text-foreground/80 mt-1.5 leading-relaxed line-clamp-3">{t.capDesc}</p>
          </div>
        </a>
      </div>
    </div>

    <div class="flex justify-center mt-10">
      <a
        href={metodoBase}
        class="group inline-flex items-center justify-center text-xs font-medium tracking-widest uppercase text-primary hover:text-sna-accent transition-all duration-200"
      >
        <span class="transition-transform duration-200 group-hover:-translate-x-1">{t.cta}</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </div>
</section>
