---
export interface Props {
  heading: string;
}

const { heading } = Astro.props;
---

<section class="py-20 lg:py-28 bg-muted">
  <div class="max-w-[800px] mx-auto px-6 lg:px-8">
    <h2 class="text-2xl lg:text-[34px] font-semibold mb-8 leading-tight">{heading}</h2>
    <div class="space-y-6 text-[15px] text-foreground/80 leading-relaxed">
      <slot />
    </div>
  </div>
</section>
