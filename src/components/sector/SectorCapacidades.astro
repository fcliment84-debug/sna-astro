---
export interface Capacidad {
  title: string;
  description: string;
}

export interface Props {
  heading: string;
  capacidades: Capacidad[];
}

const { heading, capacidades } = Astro.props;
---

<section class="py-20 lg:py-28 bg-muted">
  <div class="max-w-[900px] mx-auto px-6 lg:px-8">
    <h2 class="text-2xl lg:text-[34px] font-semibold mb-14 leading-tight">{heading}</h2>
    <div class="space-y-0">
      {capacidades.map((cap) => (
        <div class="border-t border-sna-gray-line py-8">
          <h3 class="text-lg font-semibold mb-3">{cap.title}</h3>
          <p class="text-[15px] text-foreground/80 leading-relaxed">{cap.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
