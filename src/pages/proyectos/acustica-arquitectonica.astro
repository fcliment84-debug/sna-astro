---
import BaseLayout from "../../layouts/BaseLayout.astro";
import InteriorHero from "../../components/interior/InteriorHero.astro";
import InteriorCTA from "../../components/interior/InteriorCTA.astro";
import EditorialBlock from "../../components/interior/EditorialBlock.astro";
import SectorCapacidades from "../../components/sector/SectorCapacidades.astro";
import SectorProyectos from "../../components/sector/SectorProyectos.astro";
import SectorNormativa from "../../components/sector/SectorNormativa.astro";
import { breadcrumbSchema, serviceSchema } from "../../data/schemas";

const lang = "es";

const jsonLd = [
  breadcrumbSchema([
    { name: "Inicio", url: "/" },
    { name: "Proyectos", url: "/proyectos" },
    { name: "Acústica arquitectónica" },
  ]),
  serviceSchema({
    name: "Acústica arquitectónica",
    description: "Consultoría acústica para proyectos de edificación: obra nueva, rehabilitación, hoteles, oficinas, centros educativos y salas técnicas.",
    url: "/proyectos/acustica-arquitectonica",
    capabilities: [
      "Aislamiento acústico en edificación",
      "Acondicionamiento acústico interior",
      "Control de ruido de instalaciones",
      "Cumplimiento CTE DB-HR",
      "Estudios acústicos para licencias",
      "Rehabilitación acústica",
    ],
  }),
];

const typologies = [
  { title: "Edificación residencial", description: "Aislamiento entre viviendas, aislamiento a fachada, control del ruido de instalaciones y del ruido de impacto en forjados." },
  { title: "Hoteles", description: "Privacidad entre habitaciones, aislamiento de zonas comunes a áreas de descanso, control del ruido de instalaciones de climatización." },
  { title: "Oficinas y espacios de trabajo", description: "Control de la inteligibilidad de la voz, gestión de la privacidad acústica, absorción para el control del ruido de fondo." },
  { title: "Centros educativos", description: "La calidad acústica del aula es un factor documentado de rendimiento educativo." },
  { title: "Salas técnicas: grabación, ensayo, cine privado", description: "Recintos con exigencias acústicas especiales que requieren un diseño acústico integral." },
  { title: "Edificios públicos e institucionales", description: "Proyectos acústicos en edificios con requerimientos específicos de inteligibilidad, confort o protección frente a ruido exterior." },
];

const capacidades = [
  { title: "Absorción y aislamiento: dos problemas distintos", description: "La confusión entre absorción acústica y aislamiento acústico es frecuente y tiene consecuencias en el diseño." },
  { title: "Modelización de edificios", description: "Utilizamos software de simulación acústica para modelizar el comportamiento de los sistemas constructivos en proyecto." },
  { title: "Prescripción y especificación técnica", description: "Elaboramos la documentación técnica acústica: memoria de cálculo, especificaciones de materiales y sistemas." },
  { title: "Diagnóstico de patologías en edificio construido", description: "Cuando el problema acústico existe ya en un edificio en uso, el punto de partida es el diagnóstico." },
];
---

<BaseLayout
  title="Acústica arquitectónica | SNA — Consultoría acústica en edificación"
  description="Consultoría acústica para proyectos de edificación: obra nueva, rehabilitación, hoteles, oficinas, centros educativos y salas técnicas."
  canonical="https://snaconsultoriaacustica.com/proyectos/acustica-arquitectonica/"
  jsonLd={jsonLd}
>
  <InteriorHero
    bgImage="/images/acustica-arquitectonica.webp"
    breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Proyectos", href: "/proyectos" }, { label: "Acústica arquitectónica" }]}
    title="Acústica arquitectónica: el comportamiento acústico del edificio como criterio de diseño."
    subtitle="El confort acústico de un edificio no es el resultado de añadir materiales al final del proyecto. Es una propiedad que se diseña desde el principio, se verifica antes de ejecutar y se mide al terminar."
    lang={lang}
  >
    <div class="mt-8">
      <a href="#proyectos-sector" class="group inline-flex items-center justify-center border border-white text-white px-8 py-4 text-base font-medium rounded-none hover:border-sna-accent hover:text-sna-accent transition-all duration-200">
        <span class="transition-transform duration-200 group-hover:-translate-x-1">Ver proyectos arquitectónicos</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </InteriorHero>

  <EditorialBlock title="El cumplimiento del CTE es el punto de partida, no el objetivo.">
    <p>El Código Técnico de la Edificación, en su Documento Básico DB-HR, establece los requisitos mínimos de protección frente al ruido en edificios. Cumplir esos requisitos es necesario. No es suficiente.</p>
    <p>Un edificio puede superar las mediciones de cumplimiento del DB-HR y presentar, en condiciones reales de uso, problemas acústicos significativos.</p>
    <p>En SNA trabajamos en la brecha entre el cumplimiento normativo y el resultado real.</p>
  </EditorialBlock>

  <SectorCapacidades heading="Tipologías de proyecto en acústica arquitectónica." capacidades={typologies} />

  <section class="py-20 lg:py-28">
    <div class="max-w-[800px] mx-auto px-6 lg:px-8">
      <h2 class="text-2xl lg:text-[34px] font-semibold mb-8 leading-tight">Qué hacemos en acústica arquitectónica.</h2>
      <div class="space-y-6 text-[15px] text-foreground/80 leading-relaxed">
        {capacidades.map((cap) => (
          <div>
            <h3 class="text-base font-semibold text-foreground mb-2">{cap.title}</h3>
            <p>{cap.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectorProyectos heading="Proyectos arquitectónicos representativos." sectorFilter="Arquitectónico" lang={lang} />

  <SectorNormativa heading="El marco normativo en edificación: CTE DB-HR.">
    <p>El Código Técnico de la Edificación (CTE), a través de su Documento Básico de Protección frente al Ruido (DB-HR), establece las exigencias básicas de aislamiento acústico.</p>
    <p>El DB-HR define valores mínimos de aislamiento entre recintos protegidos y recintos emisores.</p>
    <p>SNA trabaja no solo para cumplir estos requisitos mínimos, sino para garantizar que el comportamiento acústico real del edificio corresponda con las expectativas de calidad.</p>
  </SectorNormativa>

  <InteriorCTA title="¿Estás proyectando un edificio o tienes un problema acústico en uno existente?" buttonLabel="Plantear caso técnico" lang={lang} />
</BaseLayout>
