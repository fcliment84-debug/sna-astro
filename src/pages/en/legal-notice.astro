---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { breadcrumbSchema } from "../../data/schemas";

const lang = "en";

const jsonLd = breadcrumbSchema([
  { name: "Home", url: "/en" },
  { name: "Legal Notice" },
]);
---

<BaseLayout
  title="Legal Notice | SNA Acoustic Consultancy"
  description="Legal notice of SNA Acoustic Consultancy. Information on identification, liability, intellectual property, and applicable legislation."
  canonical="https://snaconsultoriaacustica.com/en/legal-notice/"
  lang="en"
  jsonLd={jsonLd}
>
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-28">
    <article class="max-w-4xl mx-auto px-6 lg:px-8 text-justify leading-relaxed">
      <h1 class="text-2xl lg:text-3xl font-bold mb-10">Legal Notice</h1>

      <!-- Identification -->
      <div class="border-b border-sna-gray-line pb-8 mb-8">
        <h2 class="border-l-2 border-primary pl-3 text-lg font-semibold text-foreground mb-4">Identification</h2>
        <div class="rounded-lg bg-muted/60 p-5 text-sm leading-relaxed space-y-1">
          <p><strong>Company name:</strong> SNA Consultoría Acústica</p>
          <p><strong>CIF:</strong> B-24661738</p>
          <p><strong>Address:</strong> Torre Europa, Paseo de la Castellana, 95, planta 29, 28046 Madrid</p>
          <p><strong>Phone:</strong> 91 838 78 66</p>
          <p><strong>Email:</strong> info@snaconsultoriaacustica.com</p>
          <p><strong>Commercial Registry:</strong> León, Tomo 1270, Libro 0, Folio 57, Sección 8, Hoja LE-22725</p>
        </div>
