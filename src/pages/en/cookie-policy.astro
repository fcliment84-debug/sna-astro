---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { breadcrumbSchema } from "../../data/schemas";

const lang = "en";

const jsonLd = breadcrumbSchema([
  { name: "Home", url: "/en" },
  { name: "Cookie Policy" },
]);
---

<BaseLayout
  title="Cookie Policy | SNA Consultoría Acústica"
  description="Information about cookies used on snaconsultoriaacustica.com. Review and manage your consent preferences."
  canonical="https://snaconsultoriaacustica.com/en/cookie-policy/"
  lang="en"
  jsonLd={jsonLd}
>
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-28">
    <article class="max-w-4xl mx-auto px-6 lg:px-8 text-justify leading-relaxed">
      <h1 class="text-2xl lg:text-3xl font-bold mb-10">Cookie Policy</h1>
      <p class="mb-8">On this page you can review the cookies used by this website and manage your consent preferences.</p>

      <!-- What is a Cookie -->
      <div class="border-b border-sna-gray-line pb-8 mb-8">
        <h2 class="border-l-2 border-primary pl-3 text-lg font-semibold text-foreground mb-4">What is a Cookie?</h2>
        <p>A cookie is a small text file that a website places on your PC, phone, or any other device, with information about your browsing on that site.</p>
      </div>

      <!-- What are cookies used for -->
      <div class="border-b border-sna-gray-line pb-8 mb-8">
        <h2 class="border-l-2 border-primary pl-3 text-lg font-semibold text-foreground mb-4">What are cookies used for on this website?</h2>
        <p>Cookies are an essential part of how our website works. The main purpose of our cookies is to improve your browsing experience.</p>
      </div>

      <!-- What are cookies NOT used for -->
      <div class="border-b border-sna-gray-line pb-8 mb-8">
        <h2 class="border-l-2 border-primary pl-3 text-lg font-semibold text-foreground mb-4">What are cookies NOT used for on this website?</h2>
        <p>We do not store sensitive personal identification information such as your address, password, credit or debit card details, etc., in the cookies we use.</p>
      </div>

      <!-- Can cookies be deleted -->
      <div class="border-b border-sna-gray-line pb-8 mb-8">
        <h2 class="border-l-2 border-primary pl-3 text-lg font-semibold text-foreground mb-4">Can cookies be deleted?</h2>
        <p>Yes, and not only deleted but also blocked, either generally or specifically for a particular domain.</p>
      </div>

      <!-- Cookiebot Cookie Declaration -->
      <div class="rounded-lg border border-sna-gray-line bg-muted/30 p-6 lg:p-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">Cookiebot</span>
          <h2 class="border-l-2 border-primary pl-3 text-lg font-semibold text-foreground">Cookie declaration</h2>
        </div>
        <p class="mb-6 text-sm text-muted-foreground">Below you can review the specific cookies used by this website and modify your consent.</p>
        <div class="cookie-declaration">
          <script is:inline id="CookieDeclaration" src="https://consent.cookiebot.com/92f8a6c8-0c0c-4a08-95d5-9c4f3cd0d43b/cd.js" type="text/javascript"></script>
        </div>
      </div>
    </article>
  </section>
</BaseLayout>
