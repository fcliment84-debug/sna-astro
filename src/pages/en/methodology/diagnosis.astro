---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import InteriorHero from "../../../components/interior/InteriorHero.astro";
import InteriorCTA from "../../../components/interior/InteriorCTA.astro";
import EditorialBlock from "../../../components/interior/EditorialBlock.astro";
import { breadcrumbSchema, serviceSchema } from "../../../data/schemas";

const lang = "en";

const jsonLd = [
  breadcrumbSchema([
    { name: "Home", url: "/en" },
    { name: "Methodology", url: "/en/methodology" },
    { name: "Diagnosis" },
  ]),
  serviceSchema({
    name: "Acoustic diagnosis",
    description: "Analysis of the real acoustic behaviour of each environment through precision measurement, acoustic camera, spectral analysis and vibration measurement.",
    url: "/en/methodology/diagnosis",
    capabilities: ["Precision acoustic measurement", "Acoustic camera (beamforming)", "Sound spectrum analysis", "Vibration measurement", "Noise maps"],
  }),
];

const tools = [
  { title: "Precision acoustic measurement", text: "Class 1 sound level meters, real-time spectrum analysers, multi-channel measurement systems. Measurements are performed in accordance with UNE and ISO standards applicable to each context." },
  { title: "Acoustic camera (beamforming)", text: "The acoustic camera allows visualising and locating noise sources with spatial precision. Particularly useful in complex industrial environments where multiple sources coexist." },
  { title: "Sound spectrum analysis", text: "Frequency analysis is fundamental for diagnosis. Low, mid and high frequencies have different physical behaviours and require different solutions." },
  { title: "Vibration measurement", text: "Structural vibrations often constitute the most critical and complex noise transmission path. Their proper characterisation is essential in diagnosing both industrial and building projects." },
  { title: "Noise maps", text: "In environmental and urban planning projects, we produce noise maps representing the spatial distribution of sound levels in the studied environment." },
];
---

<BaseLayout
  title="Acoustic diagnosis | SNA Methodology"
  description="We analyse the real acoustic behaviour of every environment before designing any solution."
  canonical="https://snaconsultoriaacustica.com/en/methodology/diagnosis/"
  lang="en"
  jsonLd={jsonLd}
>
  <InteriorHero
    breadcrumbs={[{ label: "Home", href: "/en" }, { label: "Methodology", href: "/en/methodology" }, { label: "Diagnosis" }]}
    bgImage="/images/camara-acustica-sna.webp"
    bgPosition="85% center"
    title="Diagnosis is the most important part of the work."
    subtitle="We don't measure to fill in a form. We measure to understand the real behaviour of the acoustic problem. The difference between the two approaches defines the quality of the solution."
    lang={lang}
  >
    <div class="mt-10">
      <a href="#herramientas-diagnostico" class="group inline-flex items-center justify-center border border-white text-white px-8 py-4 text-base font-medium rounded-none hover:border-sna-accent hover:text-sna-accent transition-all duration-200">
        <span class="transition-transform duration-200 group-hover:-translate-x-1">Advanced diagnostic tools</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </InteriorHero>

  <EditorialBlock title="Understanding the problem before solving anything.">
    <p>Sound does not behave uniformly. Every environment has a specific acoustic response that depends on its geometry, materials, noise sources and the paths through which sound energy is transmitted — both through the air and through the structure.</p>
    <p>A rigorous acoustic diagnosis is not limited to measuring levels in decibels. It involves analysing the sound field by frequency, identifying sources precisely and quantifying their relative contribution, analysing transmission mechanisms — airborne, impact, structural — and building a model of the system's behaviour.</p>
    <p>At SNA, diagnosis is the most demanding technical work and the one with the greatest impact on the final result.</p>
  </EditorialBlock>

  <section id="herramientas-diagnostico" class="scroll-mt-20 lg:scroll-mt-24 py-20 lg:py-28 bg-muted">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <h2 class="text-2xl lg:text-[34px] font-semibold mb-12 leading-tight max-w-[800px]">Advanced diagnostic tools.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {tools.map((tool) => (
          <div class="border-t-2 border-primary pt-6">
            <h3 class="text-lg font-medium mb-3">{tool.title}</h3>
            <p class="text-sm text-foreground/80 leading-relaxed">{tool.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-background">
    <div class="max-w-[800px] mx-auto px-6 lg:px-8">
      <h2 class="text-2xl lg:text-[34px] font-semibold mb-8 leading-tight">Regulations as context, not as a limit.</h2>
      <div class="border-l-[3px] border-secondary pl-6 space-y-6 text-foreground/80 leading-relaxed">
        <p>Acoustic diagnosis always operates within a regulatory framework: Royal Decree 286/2006 in occupational settings, the Technical Building Code (DB-HR) in construction, Royal Decree 1367/2007 on environmental matters, and Law 37/2003 on Noise.</p>
        <p>Knowing and correctly applying regulations is the minimum requirement. Our diagnosis goes further: it identifies the real problems behind the regulatory indicators.</p>
      </div>
    </div>
  </section>

  <InteriorCTA title="Do you need a technical evaluation of your acoustic problem?" buttonLabel="Request diagnosis" lang={lang} />
</BaseLayout>
