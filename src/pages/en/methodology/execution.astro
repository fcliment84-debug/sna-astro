---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import InteriorHero from "../../../components/interior/InteriorHero.astro";
import InteriorCTA from "../../../components/interior/InteriorCTA.astro";
import EditorialBlock from "../../../components/interior/EditorialBlock.astro";
import { breadcrumbSchema, serviceSchema } from "../../../data/schemas";

const lang = "en";

const jsonLd = [
  breadcrumbSchema([
    { name: "Home", url: "/en" },
    { name: "Methodology", url: "/en/methodology" },
    { name: "Execution" },
  ]),
  serviceSchema({
    name: "Acoustic execution and control",
    description: "In-house manufacturing, on-site installation and final acoustic verification with full technical responsibility.",
    url: "/en/methodology/execution",
    capabilities: ["Industrial acoustic enclosures", "Acoustic enclosures", "Absorbent and insulation panels", "Acoustic screens", "Reactive and dissipative silencers"],
  }),
];

const fabItems = [
  { title: "Industrial acoustic enclosures", text: "For isolating noisy machinery, with integrated ventilation and operational access." },
  { title: "Acoustic enclosures", text: "Modular systems for encapsulating noise sources in industrial environments." },
  { title: "Absorbent and insulation panels", text: "Designed and manufactured for the specific frequencies and applications of each project." },
  { title: "Acoustic screens", text: "Systems for outdoor protection against traffic and industrial noise." },
  { title: "Reactive and dissipative silencers", text: "For airflow, gases and ventilation ducts." },
];
---

<BaseLayout
  title="Execution and control | SNA Methodology"
  description="We manufacture and execute acoustic solutions with full technical responsibility."
  canonical="https://snaconsultoriaacustica.com/en/methodology/execution/"
  lang="en"
  jsonLd={jsonLd}
>
  <InteriorHero
    breadcrumbs={[{ label: "Home", href: "/en" }, { label: "Methodology", href: "/en/methodology" }, { label: "Execution" }]}
    bgImage="/images/ejecucion-hero.webp"
    title="Full technical responsibility, from start to finish."
    subtitle="At SNA, execution is not the delivery of a report. It is the physical application of the designed solution, with the same technical rigour as diagnosis and design, and with the final measurement that verifies the result."
    lang={lang}
  >
    <div class="mt-10">
      <a href="#fabricacion-propia" class="group inline-flex items-center justify-center border border-white text-white px-8 py-4 text-base font-medium rounded-none hover:border-sna-accent hover:text-sna-accent transition-all duration-200">
        <span class="transition-transform duration-200 group-hover:-translate-x-1">Manufacturing solutions</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </InteriorHero>

  <EditorialBlock title="In-house manufacturing, site coordination and final verification.">
    <p>At SNA we directly manufacture and execute the solutions we design. This is not merely a logistical advantage — it is what allows us to guarantee that what is installed corresponds exactly to what was calculated.</p>
    <p>Our manufacturing capabilities include industrial acoustic enclosures, machinery enclosures, absorption and insulation panels, acoustic screens and silencers.</p>
    <p>In building projects, we coordinate the installation of acoustic systems on site and work with construction teams to ensure that the installation preserves the calculated performance.</p>
  </EditorialBlock>

  <section id="fabricacion-propia" class="scroll-mt-20 lg:scroll-mt-24 py-20 lg:py-28 bg-muted">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <h2 class="text-2xl lg:text-[34px] font-semibold mb-4 leading-tight max-w-[800px]">Solutions manufactured to measure for each project.</h2>
      <p class="text-foreground/80 leading-relaxed max-w-[800px] mb-12">In-house manufacturing is partly possible thanks to the technical development accumulated over years of projects. We do not replicate commercial systems — we manufacture the elements the design requires.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-0">
        {fabItems.map((item) => (
          <div class="py-6 border-b border-sna-gray-line">
            <h3 class="text-lg font-medium mb-2">{item.title}</h3>
            <p class="text-sm text-foreground/80 leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <EditorialBlock title="The project doesn't end with installation." background="white">
    <p>Every project concludes with an on-site measurement that verifies the result against the project's technical objective.</p>
    <p>When results fall short of the objective, we identify the cause and correct it. Full technical responsibility also means accepting the necessary adjustments.</p>
  </EditorialBlock>

  <InteriorCTA title="Looking for a company that executes with the same rigour as it diagnoses?" buttonLabel="Submit a technical case" lang={lang} />
</BaseLayout>
