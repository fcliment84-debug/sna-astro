---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import InteriorHero from "../../../components/interior/InteriorHero.astro";
import InteriorCTA from "../../../components/interior/InteriorCTA.astro";
import EditorialBlock from "../../../components/interior/EditorialBlock.astro";
import { breadcrumbSchema, serviceSchema } from "../../../data/schemas";

const lang = "en";

const jsonLd = [
  breadcrumbSchema([
    { name: "Home", url: "/en" },
    { name: "Methodology", url: "/en/methodology" },
    { name: "Design" },
  ]),
  serviceSchema({
    name: "Acoustic solution design",
    description: "Bespoke acoustic solution design through FEM/BEM computational modelling and technical systems analysis for insulation, absorption and vibration control.",
    url: "/en/methodology/design",
    capabilities: ["Sound insulation", "Sound absorption", "Vibration control", "Computational acoustic modelling"],
  }),
];

const tipos = [
  { title: "Sound insulation", text: "Reduction of noise transmission between rooms or from outside. Design considers mass, damping and structural disconnection as fundamental mechanisms." },
  { title: "Sound absorption", text: "Control of reverberation time and interior acoustic quality. Design works with frequency-dependent absorption coefficients of materials." },
  { title: "Vibration control", text: "Design of structural transmission control systems — anti-vibration mounts, floating platforms, inertia slabs." },
  { title: "Computational acoustic modelling", text: "We use FEM and BEM software to build computational models of the environment, simulate behaviour and verify solutions before execution." },
];
---

<BaseLayout
  title="Acoustic design | SNA Methodology"
  description="We design bespoke acoustic solutions through computational modelling and technical systems analysis."
  canonical="https://snaconsultoriaacustica.com/en/methodology/design/"
  lang="en"
  jsonLd={jsonLd}
>
  <InteriorHero
    breadcrumbs={[{ label: "Home", href: "/en" }, { label: "Methodology", href: "/en/methodology" }, { label: "Design" }]}
    bgImage="/images/innovacion-aplicada.webp"
    title="Design as verification before execution."
    subtitle="Good design is not proposing a solution. It's being able to demonstrate, before executing it, that it will work under the project's real conditions."
    lang={lang}
  >
    <div class="mt-10">
      <a href="#tipologias-diseno" class="group inline-flex items-center justify-center border border-white text-white px-8 py-4 text-base font-medium rounded-none hover:border-sna-accent hover:text-sna-accent transition-all duration-200">
        <span class="transition-transform duration-200 group-hover:-translate-x-1">Technical solution design</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </InteriorHero>

  <EditorialBlock title="From diagnostic data to the verified solution.">
    <p>The design phase at SNA starts from the acoustic model built during diagnosis. We don't start with the solution — we start with what we know about the problem.</p>
    <p>We use finite element software (FEM) and boundary element methods (BEM) to model the behaviour of proposed solutions before executing them.</p>
    <p>The design also integrates constructive constraints, client requirements and environmental limitations. A technically correct but constructively unfeasible solution is not a good solution.</p>
  </EditorialBlock>

  <section id="tipologias-diseno" class="scroll-mt-20 lg:scroll-mt-24 py-20 lg:py-28 bg-muted">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <h2 class="text-2xl lg:text-[34px] font-semibold mb-12 leading-tight max-w-[800px]">Technical solutions for each type of problem.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-0">
        {tipos.map((tipo) => (
          <div class="py-8 border-b border-sna-gray-line">
            <h3 class="text-lg font-medium mb-3">{tipo.title}</h3>
            <p class="text-sm text-foreground/80 leading-relaxed">{tipo.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <InteriorCTA title="Would you like us to design a solution for your acoustic problem?" buttonLabel="Submit a technical case" lang={lang} />
</BaseLayout>
