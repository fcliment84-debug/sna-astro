---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Application sent | Basslock® — SNA Acoustic Consultancy"
  description="Your application for the Basslock® distribution programme has been sent successfully."
  lang="en"
  noindex={true}
  hideHeaderSpacer={true}
>
  <section class="min-h-[70vh] flex items-center justify-center bg-bl-blue relative overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center opacity-[0.06] pointer-events-none"
      style="background-image: url('/images/basslock/hero-bg.webp')"
    ></div>
    <div class="relative max-w-xl mx-auto px-6 lg:px-8 text-center py-20 lg:py-28">
      <a href="/en/basslock" class="inline-block mb-10">
        <img
          src="/images/basslock/logo-horizontal-negativo-new.webp"
          alt="Basslock®"
          class="h-14 w-auto mx-auto opacity-80 hover:opacity-100 transition-opacity"
        />
      </a>

      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-bl-lime/20 mb-8">
        <svg class="w-10 h-10 text-bl-lime" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-2xl lg:text-3xl font-semibold text-white mb-4">Application sent successfully</h1>
      <p class="text-base text-white/70 leading-relaxed mb-2">You will receive a confirmation email shortly.</p>
      <p class="text-base text-white/70 leading-relaxed mb-10">We will review your profile and get in touch within the next few working days.</p>

      <a
        href="/en/basslock"
        class="group inline-flex items-center justify-center bg-bl-lime text-bl-blue px-8 py-4 text-base font-medium rounded-none hover:bg-white transition-all duration-200"
      >
        <span class="transition-transform duration-200 group-hover:-translate-x-1">Back to Basslock</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </section>
</BaseLayout>
