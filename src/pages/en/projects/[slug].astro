---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import InteriorCTA from "../../../components/interior/InteriorCTA.astro";
import ProjectGalleryLightbox from "../../../components-react/ProjectGalleryLightbox";
import { projects, getProjectThumbnail, localizeProject, sectorLabelsMap, solutionTypeLabelsMap } from "../../../data/projects";
import { projectGalleries } from "../../../data/projectGalleries";
import { localePath } from "../../../data/navigation";
import { breadcrumbSchema } from "../../../data/schemas";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const lang = "en";
const p = localizeProject(project, lang);
const thumbnail = getProjectThumbnail(project.slug);
const gallery = projectGalleries[project.slug];
const containGallery = project.slug === "ruido-estructural-data-center-comsol";

/* Related projects: same sector = 2 pts, same solutionType = 1 pt, top 3 */
const related = projects
  .filter((r) => r.slug !== project.slug)
  .sort((a, b) => {
    const aScore = (a.sector === project.sector ? 2 : 0) + (a.solutionType === project.solutionType ? 1 : 0);
    const bScore = (b.sector === project.sector ? 2 : 0) + (b.solutionType === project.solutionType ? 1 : 0);
    return bScore - aScore;
  })
  .slice(0, 3);

const sectorColorMap: Record<string, string> = {
  Industrial: "text-primary",
  "Arquitectónico": "text-secondary",
  Medioambiental: "text-sna-green",
};

const boltClip = "polygon(16px 0, 100% 0, 100% calc(100% - 16px), calc(100% - 16px) 100%, 0 100%, 0 16px)";

const jsonLd = breadcrumbSchema([
  { name: "Home", url: "/en" },
  { name: "Projects", url: "/en/projects" },
  { name: p.title },
]);
---

<BaseLayout
  title={`${p.title} — Projects SNA`}
  description={p.tagline}
  canonical={`https://snaconsultoriaacustica.com/en/projects/${project.slug}/`}
  lang="en"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative pt-28 pb-16 lg:pt-36 lg:pb-24 overflow-hidden">
    {thumbnail && (
      <img src={thumbnail} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full img-cover" />
    )}
    <div class="absolute inset-0" style="background-color:rgba(0,0,0,0.65)"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-1.5 text-sm font-medium text-white/70">
          <li class="flex items-center gap-1.5">
            <a href={localePath("/", lang)} class="hover:text-white transition-colors">Home</a>
          </li>
          <li class="flex items-center gap-1.5">
            <span class="select-none">/</span>
            <a href={localePath("/proyectos", lang)} class="hover:text-white transition-colors">Projects</a>
          </li>
          <li class="flex items-center gap-1.5">
            <span class="select-none">/</span>
            <span class="text-white">{p.title}</span>
          </li>
        </ol>
      </nav>
      <div class="flex items-center gap-1.5 mb-4">
        <span class="text-13 font-medium uppercase tracking-widest text-sna-accent">{p.sector}</span>
        <span class="text-white/50 text-13">&middot;</span>
        <span class="text-13 font-medium uppercase tracking-widest text-white/60">{p.solutionType}</span>
      </div>
      <h1 class="text-3xl lg:text-5xl font-semibold max-w-800 text-white">{p.title}</h1>
      <p class="mt-6 text-lg text-white/80 max-w-700 leading-relaxed" style="text-align:left">{p.tagline}</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Mobile sidebar -->
      <div class="lg:hidden mb-12">
        <aside class="bg-muted p-8">
          <h3 class="text-base font-semibold uppercase tracking-widest text-foreground mb-6">Key data</h3>
          <div class="border-t border-sna-gray-line pt-6">
            <dl class="grid grid-cols-2 gap-x-6">
              <div class="mb-5">
                <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Location</dt>
                <dd class="text-15 text-foreground">{p.location}</dd>
              </div>
              <div class="mb-5">
                <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Sector</dt>
                <dd class="text-15 text-foreground">{p.sector}</dd>
              </div>
              <div class="mb-5">
                <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Solution type</dt>
                <dd class="text-15 text-foreground">{p.solutionType}</dd>
              </div>
              <div class="mb-5">
                <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Key figure</dt>
                <dd class="text-15 text-foreground">{p.keyFigure}</dd>
              </div>
              {p.regulation && (
                <div class="mb-5">
                  <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Regulation</dt>
                  <dd class="text-15 text-foreground">{p.regulation}</dd>
                </div>
              )}
              {p.technology && (
                <div class="mb-5">
                  <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Technology</dt>
                  <dd class="text-15 text-foreground">{p.technology}</dd>
                </div>
              )}
            </dl>
          </div>
        </aside>
      </div>

      <div class="project-layout">
        <!-- Main content -->
        <div class="project-content">
          <!-- Challenge -->
          <div>
            <h2 class="text-xl lg:text-2xl font-semibold mb-4">The challenge</h2>
            <div class="section-line"></div>
            <div class="space-y-6 text-foreground/80 leading-relaxed">
              {p.challenge.split("\n\n").map((paragraph: string) => <p>{paragraph}</p>)}
            </div>
          </div>
          <!-- Solution -->
          <div class="mt-12">
            <h2 class="text-xl lg:text-2xl font-semibold mb-4">The solution</h2>
            <div class="section-line"></div>
            <div class="space-y-6 text-foreground/80 leading-relaxed">
              {p.solution.split("\n\n").map((paragraph: string) => <p>{paragraph}</p>)}
            </div>
          </div>
          <!-- Result -->
          <div class="mt-12">
            <h2 class="text-xl lg:text-2xl font-semibold mb-4">The result</h2>
            <div class="section-line"></div>
            <div class="space-y-6 text-foreground/80 leading-relaxed">
              {p.result.split("\n\n").map((paragraph: string) => <p>{paragraph}</p>)}
            </div>
          </div>
        </div>

        <!-- Desktop sidebar -->
        <div class="project-sidebar">
          <aside class="bg-muted p-8 sticky top-28">
            <h3 class="text-base font-semibold uppercase tracking-widest text-foreground mb-6">Key data</h3>
            <div class="border-t border-sna-gray-line pt-6">
              <dl class="grid grid-cols-1">
                <div class="mb-5">
                  <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Location</dt>
                  <dd class="text-15 text-foreground">{p.location}</dd>
                </div>
                <div class="mb-5">
                  <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Sector</dt>
                  <dd class="text-15 text-foreground">{p.sector}</dd>
                </div>
                <div class="mb-5">
                  <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Solution type</dt>
                  <dd class="text-15 text-foreground">{p.solutionType}</dd>
                </div>
                <div class="mb-5">
                  <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Key figure</dt>
                  <dd class="text-15 text-foreground">{p.keyFigure}</dd>
                </div>
                {p.regulation && (
                  <div class="mb-5">
                    <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Regulation</dt>
                    <dd class="text-15 text-foreground">{p.regulation}</dd>
                  </div>
                )}
                {p.technology && (
                  <div class="mb-5">
                    <dt class="text-13 font-medium uppercase tracking-widest text-secondary mb-1">Technology</dt>
                    <dd class="text-15 text-foreground">{p.technology}</dd>
                  </div>
                )}
              </dl>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  {gallery && gallery.length > 0 && (
    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <ProjectGalleryLightbox
          images={containGallery ? gallery.map((img) => ({ ...img, contain: true })) : gallery}
          client:visible
        />
      </div>
    </section>
  )}

  <!-- Related Projects -->
  <section class="bg-muted py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <h2 class="text-2xl lg:text-3xl font-semibold mb-12">Related projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {related.map((rel) => {
          const rt = localizeProject(rel, lang);
          const rThumb = getProjectThumbnail(rel.slug);
          const colors = sectorColorMap[rel.sector] || "text-primary";
          return (
            <a
              href={`/en/projects/${rel.slug}`}
              class="group relative block overflow-hidden bg-background transition-all duration-500 shadow-none border-b-2 border-transparent hover:shadow-xl hover:border-sna-accent"
              style={`clip-path: ${boltClip}`}
            >
              <div class="absolute inset-0 z-10 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 related-overlay"></div>
              <div class="overflow-hidden">
                <div class="bg-muted flex items-center justify-center" style="aspect-ratio:16/5">
                  {rThumb ? (
                    <img src={rThumb} alt={rt.title} class="related-thumb" loading="lazy" />
                  ) : (
                    <span class="text-xs text-muted-foreground select-none">[Image]</span>
                  )}
                </div>
              </div>
              <div class="relative z-20 p-6">
                <div class="flex items-center gap-1.5 mb-3">
                  <span class:list={["text-13 font-medium uppercase tracking-widest transition-colors duration-500 group-hover:text-sna-accent", colors]}>{rt.sector}</span>
                  <span class="text-muted-foreground text-13">&middot;</span>
                  <span class="text-13 font-medium uppercase tracking-widest text-muted-foreground">{rt.solutionType}</span>
                </div>
                <h3 class="text-lg font-medium mb-2 leading-snug">{rt.title}</h3>
                <p class="text-sm text-foreground/80 leading-relaxed line-clamp-2 mb-4">{rt.tagline}</p>
                <span class="text-sm font-medium text-primary inline-flex items-center gap-1">
                  <span>View project</span>
                  <span class="transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <InteriorCTA title="Do you have a similar acoustic challenge?" buttonLabel="Submit a technical case" lang={lang} />
</BaseLayout>

<style>
  .project-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .project-sidebar {
    display: none;
  }
  @media (min-width: 1024px) {
    .project-layout {
      grid-template-columns: 2fr 1fr;
      gap: 4rem;
    }
    .project-sidebar {
      display: block;
    }
  }

  /* Section title line */
  .section-line {
    width: 2.5rem;
    height: 2px;
    background-color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  /* Gallery grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    grid-auto-rows: 280px;
  }
  @media (min-width: 1024px) {
    .gallery-grid {
      grid-auto-rows: 360px;
    }
  }
  .gallery-item {
    overflow: hidden;
    border-radius: 0.5rem;
  }
  .gallery-contain {
    background-color: hsl(210 9% 96% / 0.3);
  }
  .gallery-wide {
    grid-column: span 2;
  }
  .gallery-tall {
    grid-row: span 2;
  }
  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .gallery-img.img-contain {
    object-fit: contain;
  }
  .gallery-img:hover {
    transform: scale(1.02);
  }

  /* Object-fit helpers (Tailwind doesn't generate these in bracket-named files) */
  .img-cover {
    object-fit: cover;
  }
  .related-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .related-thumb:hover {
    transform: scale(1.05);
  }

  /* Arbitrary value replacements (Tailwind 4 won't generate these in bracket-named files) */
  .text-13 {
    font-size: 13px;
  }
  .text-15 {
    font-size: 15px;
  }
  .max-w-800 {
    max-width: 800px;
  }
  .max-w-700 {
    max-width: 700px;
  }
  .related-overlay {
    background-color: hsl(78 83% 60% / 0.07);
    box-shadow: inset 0 0 30px hsl(78 83% 60% / 0.12);
  }
</style>
