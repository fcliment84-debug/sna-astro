---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import InteriorHero from "../../../components/interior/InteriorHero.astro";
import InteriorCTA from "../../../components/interior/InteriorCTA.astro";
import EditorialBlock from "../../../components/interior/EditorialBlock.astro";
import SectorCapacidades from "../../../components/sector/SectorCapacidades.astro";
import SectorProyectos from "../../../components/sector/SectorProyectos.astro";
import SectorNormativa from "../../../components/sector/SectorNormativa.astro";
import { breadcrumbSchema, serviceSchema } from "../../../data/schemas";

const lang = "en";

const jsonLd = [
  breadcrumbSchema([
    { name: "Home", url: "/en" },
    { name: "Projects", url: "/en/projects" },
    { name: "Environmental acoustics" },
  ]),
  serviceSchema({
    name: "Environmental acoustics",
    description: "Acoustic impact assessment, strategic noise mapping, acoustic barriers and solutions for infrastructure and urban planning.",
    url: "/en/projects/environmental-acoustics",
    capabilities: [
      "Acoustic impact assessment",
      "Noise maps",
      "Acoustic barriers and screens",
      "Environmental noise monitoring",
      "Noise action plans",
    ],
  }),
];

const capacidades = [
  { title: "Acoustic impact assessment", description: "Preparation of acoustic impact studies for new activities, industries, infrastructure, or urban planning projects." },
  { title: "Noise maps", description: "Preparation of strategic noise maps in accordance with European Directive 2002/49/EC and Law 37/2003." },
  { title: "Acoustic barriers and screens", description: "Design and installation of acoustic barriers for the protection of inhabited areas from road, rail, or industrial noise." },
  { title: "Environmental noise monitoring", description: "Continuous monitoring systems for the control of acoustic impact from activities with high temporal variability." },
  { title: "BEM/FEM acoustic modelling", description: "Boundary element methods (BEM) and finite element methods (FEM) to accurately model propagation in geometrically complex environments." },
];
---

<BaseLayout
  title="Environmental Acoustics | SNA — Impact assessment and environmental noise solutions"
  description="Acoustic impact assessment, noise maps, acoustic barriers, and infrastructure solutions."
  canonical="https://snaconsultoriaacustica.com/en/projects/environmental-acoustics/"
  lang="en"
  jsonLd={jsonLd}
>
  <InteriorHero
    bgImage="/images/acustica-medioambiental.webp"
    breadcrumbs={[{ label: "Home", href: "/en" }, { label: "Projects", href: "/en/projects" }, { label: "Environmental acoustics" }]}
    title="Environmental acoustics: noise in the environment as a technical and social problem."
    subtitle="Environmental noise has measurable causes, documented effects, and concrete technical solutions. We diagnose its behaviour, assess its impact, and design the necessary interventions."
    lang={lang}
  >
    <div class="mt-8">
      <a href="#proyectos-sector" class="group inline-flex items-center justify-center border border-white text-white px-8 py-4 text-base font-medium rounded-none hover:border-sna-accent hover:text-sna-accent transition-all duration-200">
        <span class="transition-transform duration-200 group-hover:-translate-x-1">View environmental projects</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </InteriorHero>

  <EditorialBlock title="From noise map to effective technical solution.">
    <p>Environmental noise management involves rigorous technical work at every stage: characterising the sound field in the environment, assessing the impact on people and land use, correctly interpreting the regulatory framework, and designing the most appropriate protection measures.</p>
    <p>At SNA we approach environmental acoustic projects with the same diagnostic depth as industrial or building projects.</p>
    <p>Our computational modelling capability — including BEM methods for free-field propagation — allows us to build predictive models that optimise protection solutions before execution.</p>
  </EditorialBlock>

  <SectorCapacidades heading="What we do in environmental acoustics." capacidades={capacidades} />
  <SectorProyectos heading="Representative environmental projects." sectorFilter="Medioambiental" lang={lang} />

  <SectorNormativa heading="Environmental noise regulatory framework in Spain.">
    <p>Law 37/2003, of 17 November, on Noise, is the framework regulation governing acoustic pollution in Spain.</p>
    <p>Royal Decree 1367/2007, of 19 October, develops Law 37/2003 regarding acoustic zoning, quality objectives, and acoustic emissions.</p>
    <p>Precise knowledge of this regulatory framework — and its practical implications for each type of project — is part of the technical work in environmental acoustics.</p>
  </SectorNormativa>

  <InteriorCTA title="Need to assess the acoustic impact of an activity or protect an environment from noise?" buttonLabel="Submit a technical case" lang={lang} />
</BaseLayout>
