---
import BaseLayout from "../../layouts/BaseLayout.astro";
import InteriorHero from "../../components/interior/InteriorHero.astro";
import InteriorCTA from "../../components/interior/InteriorCTA.astro";
import EditorialBlock from "../../components/interior/EditorialBlock.astro";
import { breadcrumbSchema, serviceSchema } from "../../data/schemas";

const lang = "es";

const jsonLd = [
  breadcrumbSchema([
    { name: "Inicio", url: "/" },
    { name: "Metodología", url: "/metodologia" },
    { name: "Diseño" },
  ]),
  serviceSchema({
    name: "Diseño de soluciones acústicas",
    description: "Diseño de soluciones acústicas a medida mediante modelización computacional FEM/BEM y análisis técnico de sistemas de aislamiento, absorción y control de vibraciones.",
    url: "/metodologia/diseno",
    capabilities: ["Aislamiento acústico", "Absorción acústica", "Control de vibraciones", "Modelización acústica computacional"],
  }),
];

const tipos = [
  { title: "Aislamiento acústico", text: "Reducción de la transmisión de ruido entre recintos o desde el exterior. El diseño considera la masa, la amortiguación y la desconexión estructural como mecanismos fundamentales." },
  { title: "Absorción acústica", text: "Control del tiempo de reverberación y la calidad acústica interior. El diseño trabaja con el coeficiente de absorción de los materiales en función de la frecuencia." },
  { title: "Control de vibraciones", text: "Diseño de sistemas de control de transmisión estructural — soportes antivibratorios, bancadas flotantes, losas de inercia." },
  { title: "Modelización acústica computacional", text: "Utilizamos software FEM y BEM para construir modelos computacionales del entorno, simular comportamiento y verificar soluciones antes de ejecutarlas." },
];
---

<BaseLayout
  title="Diseño acústico | Metodología SNA"
  description="Diseñamos soluciones acústicas a medida mediante modelización computacional y análisis técnico de sistemas."
  canonical="https://snaconsultoriaacustica.com/metodologia/diseno/"
  jsonLd={jsonLd}
>
  <InteriorHero
    breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Metodología", href: "/metodologia" }, { label: "Diseño" }]}
    bgImage="/images/innovacion-aplicada.webp"
    title="El diseño como verificación antes de la ejecución."
    subtitle="Diseñar bien no es proponer una solución. Es poder demostrar, antes de ejecutarla, que va a funcionar en las condiciones reales del proyecto."
    lang={lang}
  >
    <div class="mt-10">
      <a href="#tipologias-diseno" class="group inline-flex items-center justify-center border border-white text-white px-8 py-4 text-base font-medium rounded-none hover:border-sna-accent hover:text-sna-accent transition-all duration-200">
        <span class="transition-transform duration-200 group-hover:-translate-x-1">Diseño de soluciones técnicas</span>
        <span class="max-w-0 overflow-hidden opacity-0 group-hover:max-w-[20px] group-hover:opacity-100 transition-all duration-200 ml-0 group-hover:ml-2">&rarr;</span>
      </a>
    </div>
  </InteriorHero>

  <EditorialBlock title="De los datos del diagnóstico a la solución verificada.">
    <p>La fase de diseño en SNA parte del modelo acústico construido durante el diagnóstico. No comenzamos por la solución: comenzamos por lo que sabemos del problema.</p>
    <p>Utilizamos software de elementos finitos (FEM) y métodos de elementos de contorno (BEM) para modelizar el comportamiento de las soluciones propuestas antes de ejecutarlas.</p>
    <p>El diseño también integra los condicionantes constructivos, los requisitos del cliente y las limitaciones del entorno. Una solución técnicamente correcta pero constructivamente inviable no es una buena solución.</p>
  </EditorialBlock>

  <section id="tipologias-diseno" class="scroll-mt-20 lg:scroll-mt-24 py-20 lg:py-28 bg-muted">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <h2 class="text-2xl lg:text-[34px] font-semibold mb-12 leading-tight max-w-[800px]">Soluciones técnicas para cada tipo de problema.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-0">
        {tipos.map((tipo) => (
          <div class="py-8 border-b border-sna-gray-line">
            <h3 class="text-lg font-medium mb-3">{tipo.title}</h3>
            <p class="text-sm text-foreground/80 leading-relaxed">{tipo.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <InteriorCTA title="¿Quieres que diseñemos una solución para tu problema acústico?" buttonLabel="Plantear caso técnico" lang={lang} />
</BaseLayout>
