---
import BaseLayout from "../layouts/BaseLayout.astro";
import InteriorHero from "../components/interior/InteriorHero.astro";
import ContactForm from "../components-react/ContactForm";
import { breadcrumbSchema, professionalServiceSchema } from "../data/schemas";

const lang = "es";

const jsonLd = [
  breadcrumbSchema([
    { name: "Inicio", url: "/" },
    { name: "Contacto" },
  ]),
  professionalServiceSchema,
];
---

<BaseLayout
  title="Contacto | SNA — Consultoría acústica"
  description="Contacta con SNA Consultoría Acústica. Oficinas en Madrid y Asturias."
  canonical="https://snaconsultoriaacustica.com/contacto/"
  jsonLd={jsonLd}
>
  <InteriorHero
    bgImage="/images/contacto-hero.webp"
    compact
    breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Contacto" }]}
    title="Hablemos de tu proyecto acústico"
    subtitle="Analizamos el problema y te indicamos cómo podemos abordarlo. La primera consulta no tiene coste."
    lang={lang}
  />

  <section id="contacto-section" class="relative py-20 lg:py-28 overflow-hidden">
    <div
      id="contacto-parallax-bg"
      class="absolute inset-0 bg-cover bg-center pointer-events-none scale-110 opacity-[0.03]"
      style="background-image: url('/images/contacto-hero.webp'); background-attachment: fixed"
    ></div>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <p class="text-base text-foreground/80 leading-relaxed mb-12 max-w-4xl">
        <strong>Desde nuestras oficinas en Madrid y Asturias, ofrecemos cobertura en todo el territorio nacional,</strong> garantizando servicio técnico y asesoramiento especializado en cualquier punto de España, <strong>incluidos los archipiélagos Balear y Canario</strong>. Nuestra estructura operativa nos permite adaptarnos a las necesidades de cada proyecto, independientemente de su ubicación.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Contact info -->
        <div class="space-y-8">
          <!-- WhatsApp -->
          <a
            href="https://wa.me/34669307211"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-4 p-6 border border-sna-gray-line bg-muted hover:border-sna-accent transition-colors duration-200"
          >
            <svg class="w-6 h-6 text-[#25D366] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            <div>
              <span class="text-sm font-semibold">WhatsApp</span>
              <span class="block text-sm text-foreground/80 mt-0.5">+34 669 307 211</span>
            </div>
          </a>

          <!-- Offices -->
          <div>
            <h3 class="text-lg font-semibold mb-5">Oficinas</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="p-6 border border-sna-gray-line">
                <h4 class="text-sm font-semibold mb-2">Madrid</h4>
                <p class="text-sm text-foreground/80 leading-relaxed">Torre Europa<br />Paseo de la Castellana, 95<br />Planta 29<br />28046 Madrid</p>
                <p class="text-sm text-foreground/80 mt-3">Tel. 91 838 78 66</p>
              </div>
              <div class="p-6 border border-sna-gray-line">
                <h4 class="text-sm font-semibold mb-2">Asturias (Oviedo)</h4>
                <p class="text-sm text-foreground/80 leading-relaxed">C/ Monte Cerrado 28<br />Bajo izq<br />33006 Oviedo</p>
                <p class="text-sm text-foreground/80 mt-3">Tel. 984 017 971</p>
              </div>
            </div>
          </div>

          <p class="text-sm text-secondary">Respondemos en un plazo máximo de 48 horas hábiles. La primera consulta no tiene coste.</p>
        </div>

        <!-- Form -->
        <ContactForm lang={lang} client:visible />
      </div>
    </div>
  </section>

  <script>
    const section = document.getElementById("contacto-section");
    const bg = document.getElementById("contacto-parallax-bg");
    if (section && bg) {
      const update = () => {
        const rect = section.getBoundingClientRect();
        const vh = window.innerHeight;
        const progress = Math.max(0, Math.min(1, (vh - rect.top) / (vh + rect.height)));
        // 0.03 → 0.14 → 0.03
        const opacity = progress < 0.5
          ? 0.03 + (0.14 - 0.03) * (progress / 0.5)
          : 0.14 - (0.14 - 0.03) * ((progress - 0.5) / 0.5);
        bg.style.opacity = String(opacity);
      };
      window.addEventListener("scroll", update, { passive: true });
      update();
    }
  </script>
</BaseLayout>
